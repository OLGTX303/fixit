{
  "info": {
    "name": "FixIt PR3 API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register customer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"Test User\",\"email\":\"test@example.com\",\"password\":\"password123\",\"role\":\"customer\"}"
            }
          }
        },
        {
          "name": "Login customer",
          "event": [{
            "listen": "test",
            "script": {
              "exec": ["const j = pm.response.json(); if (j.token) pm.collectionVariables.set('token', j.token);"]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"alex@email.com\",\"password\":\"password123\"}"
            }
          }
        },
        {
          "name": "Login admin",
          "event": [{
            "listen": "test",
            "script": {
              "exec": ["const j = pm.response.json(); if (j.token) pm.collectionVariables.set('token', j.token);"]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"admin@fixit.com\",\"password\":\"password123\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Public",
      "item": [
        {
          "name": "Health",
          "request": { "method": "GET", "url": "{{baseUrl}}/health" }
        },
        {
          "name": "Categories",
          "request": { "method": "GET", "url": "{{baseUrl}}/categories" }
        },
        {
          "name": "Providers (verified)",
          "request": { "method": "GET", "url": "{{baseUrl}}/providers?maxPrice=100&minRating=4" }
        },
        {
          "name": "Provider by id",
          "request": { "method": "GET", "url": "{{baseUrl}}/providers/1" }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "List bookings (auth)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/bookings"
          }
        },
        {
          "name": "Create booking",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/bookings",
            "body": {
              "mode": "raw",
              "raw": "{\"provider_id\":1,\"category_id\":1,\"scheduled_at\":\"2026-07-01 10:00:00\",\"address\":\"1 Test St\",\"total\":90,\"notes\":\"Test booking\"}"
            }
          }
        },
        {
          "name": "Update status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/bookings/2848/status",
            "body": { "mode": "raw", "raw": "{\"status\":\"accepted\"}" }
          }
        },
        {
          "name": "Bookings without token (401)",
          "request": { "method": "GET", "url": "{{baseUrl}}/bookings" }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Pending providers",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/admin/providers/pending"
          }
        },
        {
          "name": "Verify provider",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/admin/providers/5/verify",
            "body": { "mode": "raw", "raw": "{\"is_verified\":true}" }
          }
        },
        {
          "name": "Admin route as customer (403)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/admin/providers/pending"
          }
        }
      ]
    },
    {
      "name": "Messages",
      "item": [
        {
          "name": "List messages",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/jobs/2847/messages"
          }
        },
        {
          "name": "Send message",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/jobs/2847/messages",
            "body": { "mode": "raw", "raw": "{\"body\":\"Hello from Postman\"}" }
          }
        }
      ]
    }
  ]
}