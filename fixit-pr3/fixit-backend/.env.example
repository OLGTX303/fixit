DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=fixit
DB_USER=fixit
DB_PASS=change-me-strong-db-password
JWT_SECRET=change-me-to-a-random-string-at-least-32-characters-long
# Comma-separated. Include Capacitor Android origins (https://localhost) when using the app.
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,https://fixit.olgtx.com,http://fixit.olgtx.com,https://localhost,capacitor://localhost,http://localhost
APP_DEBUG=false

# SMTP (email OTP for changing account email). STARTTLS on port 587.
SMTP_HOST=mail.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=FixIt

# Google Maps JS API key — served to the client via GET /api/config/maps.
# Restrict this key in Google Cloud Console (Maps JavaScript API + app restrictions).
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Stripe — TEST MODE ONLY (never use sk_live_ / pk_live_ here)
STRIPE_MODE=test
STRIPE_SECRET_KEY=sk_test_your_test_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_test_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# Face match gateway (LAN) — compares the KYC ID photo against the live selfie.
FACE_MATCH_URL=http://192.168.1.219:18080/match/images
FACE_MATCH_API_KEY=your_face_match_api_key
FACE_MATCH_MIN_SCORE=65

# Chat push notifications (see PUSH_SETUP.md). Each transport is optional —
# leave blank to disable that platform; messaging still works without push.
# Web Push (browser): generate a VAPID keypair (e.g. `web-push generate-vapid-keys`).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@fixit.olgtx.com
# Android (FCM legacy server key) from Firebase Console → Project settings → Cloud Messaging.
FCM_SERVER_KEY=
